# Environment variables for garmin-ai-coach (example only)
# Copy to .env or .env.dev and fill in real values. Do NOT commit real secrets.

# LLM providers (use at least one)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=...
DEEPSEEK_API_KEY=...

# Observability (optional)
LANGSMITH_API_KEY=lsv2_...

# App mode: development | standard | cost_effective | pro | local
# Provider mapping depends on AI mode (see services/ai/ai_settings.py:24 stage_models)
# Defaults:
#   standard -> OpenAI (gpt-5)                  | requires OPENAI_API_KEY
#   development -> Anthropic (claude-4)         | requires ANTHROPIC_API_KEY
#   cost_effective -> Anthropic (claude-3-haiku) | requires ANTHROPIC_API_KEY
#   pro -> OpenAI (gpt-5.2-pro-search for experts/planners) | requires OPENAI_API_KEY
#   local -> Local Ollama (command-r)           | requires OLLAMA_BASE_URL
#        ⚠️  WARNING: PRO mode can incur high costs (>$10 per run depending on data volume)
# Tip: If you only set OPENAI_API_KEY, set AI_MODE=standard or update stage_models.
AI_MODE=local

# Local AI settings (used if AI_MODE=local)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=command-r

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
